# Discord
DISCORD_WEBHOOK_URL=

# Rakuten Web Service (https://webservice.rakuten.co.jp/ で無料登録)
# 2026年のAPI改定でAccess Keyが必須になった(Application IDだけでは呼べない)。
# アプリ管理画面の「Access Key」を目のアイコンで表示してコピーする。
RAKUTEN_APPLICATION_ID=
RAKUTEN_ACCESS_KEY=
RAKUTEN_AFFILIATE_ID=

# Amazon Creators API
# PA-API(旧API)は2026年5月15日に廃止済み。Associates Central > Tools > Creators API から
# Credential ID / Credential Secret を発行して設定する(OAuth2方式、AWS署名は不要)。
AMAZON_CREDENTIAL_ID=
AMAZON_CREDENTIAL_SECRET=
AMAZON_PARTNER_TAG=
AMAZON_COUNTRY=JP

# Yahoo!ショッピング Web API (https://e.developer.yahoo.co.jp/ で無料登録)
# 「ID連携を利用しない」でアプリ登録するとClient IDのみで商品検索APIが使える(売上実績等の条件なし)
YAHOO_CLIENT_ID=
